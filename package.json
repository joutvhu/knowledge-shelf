{
  "name": "knowledge-shelf",
  "version": "1.0.0",
  "description": "Knowledge Shelf MCP Server — on-demand documentation, templates, and workflow automation for AI",
  "type": "module",
  "bin": {
    "knowledge-shelf": "./dist/index.js"
  },
  "main": "./dist/index.js",
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/index.ts",
